# =============================================================================
# Kalshi Bot — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Kalshi API Credentials (required)
# -----------------------------------------------------------------------------

# Your Kalshi API key ID (from kalshi.com → Settings → API Keys)
KALSHI_KEY_ID=your-key-id-here

# Your RSA private key as a single-line string with literal \n for newlines.
# Example: -----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----
KALSHI_PRIVATE_KEY_STR=-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----

# API environment: "production" (real markets) or "demo" (sandbox, no settlement)
# Production endpoint: https://api.elections.kalshi.com/trade-api/v2
# Demo endpoint:       https://demo-api.kalshi.co/trade-api/v2
KALSHI_ENVIRONMENT=production

# -----------------------------------------------------------------------------
# Trading Mode (safety)
# -----------------------------------------------------------------------------

# Set to "false" ONLY when you are ready to place real orders.
# true  → dry-run: logs intended trades to SQLite, no orders sent (default)
# false → live: real orders placed via the Kalshi API
TRADE_DRY_RUN=true

# -----------------------------------------------------------------------------
# Poll & Market Settings
# -----------------------------------------------------------------------------

# How often to run a full fetch-match-report cycle (seconds). Default: 60
POLL_INTERVAL=60

# How often to re-fetch the full Kalshi market list (seconds). Default: 300
MARKET_REFRESH_INTERVAL=300

# Only consider markets closing within this many days. Default: 30
MARKET_MAX_DAYS_OUT=30

# Only consider markets closing at least this many minutes from now. Default: 30
# Prevents betting on markets already in their final moments.
MARKET_MIN_MINUTES_TO_CLOSE=30

# Orderbook liquidity filters — skip markets with wide spreads or low volume
LIQUIDITY_MAX_SPREAD=10   # max bid-ask spread in cents. Default: 10
LIQUIDITY_MIN_VOLUME=0    # min cumulative volume. Default: 0 (disabled)

# Minutes before the same opportunity can be re-surfaced. Default: 60
OPPORTUNITY_COOLDOWN_MINUTES=60

# Skip markets where we already hold this many contracts or more. Default: 5
POSITION_SKIP_CONTRACTS=5

# -----------------------------------------------------------------------------
# Trade Sizing & Risk (Kelly criterion)
# -----------------------------------------------------------------------------

# Maximum dollars (in cents) to allocate to a single trade. Default: 750 (=$7.50)
MAX_POSITION_CENTS=750

# Number of recent resolved trades used to compute the drawdown equity curve.
# Limits the lookback so early low-quality losses (pre-score-gate) don't
# permanently suppress position sizing. Default: 50. Set to 0 for all-time history.
DRAWDOWN_LOOKBACK_TRADES=50

# Fractional Kelly multiplier. 0.25 = quarter-Kelly (conservative).
# Increase toward 0.5 after calibrating win rates from dry-run data.
KELLY_FRACTION=0.25

# Default P(win) estimate when no per-metric prior is configured. Default: 0.60
KELLY_DEFAULT_P=0.60

# Per-metric P(win) priors as JSON. Set after dry-run calibration.
# Example: KELLY_METRIC_PRIORS={"temp_high": 0.68, "price_btc": 0.62}
KELLY_METRIC_PRIORS={}

# Hard cap on contracts per trade regardless of Kelly. Default: 10
TRADE_MAX_CONTRACTS=10

# Minimum composite score [0–1] required to attempt a trade. Default: 0.5
TRADE_MIN_SCORE=0.5

# Minutes before a resting passive limit order is auto-cancelled (live only).
# Passive midpoint orders may sit unfilled; this prevents stale orders from
# lingering after the signal is no longer valid. Set to 0 to disable. Default: 5
FILL_TIMEOUT_MINUTES=5

# Minimum edge (numeric) or divergence (poly) required for a counter-direction
# signal to trigger an early exit of an existing position. Set to 0 to disable
# (default). Recommend setting to your minimum entry edge after calibration.
# Example: COUNTER_SIGNAL_MIN_EDGE=1.0
COUNTER_SIGNAL_MIN_EDGE=0

# Trailing stop-loss: exit if the position was ever up by more than this
# fraction of cost, and has since drawn back by EXIT_TRAILING_DRAWDOWN from
# that peak. E.g. 0.30 means: peak was +40%, now at +10% → drawdown of 30pp
# → exit. Set to 0 to disable (default). Only fires when peak > threshold.
EXIT_TRAILING_DRAWDOWN=0

# Source-specific profit-take thresholds (JSON dict).
# Keys are "source" or "source:side". Lookup order: exact composite key → bare
# source key → global EXIT_PROFIT_TAKE fallback. Override the entire dict to
# customize any source. Key values below reflect backtest-tuned defaults.
# band_arb:yes=0.15 — backtest: 77% PT rate using intraday highs; YES spikes sharply and holds
# band_arb:no=2.00  — effectively disabled; NO signals run to capital_recycle/settlement (e.g. trade #121)
# band_arb:no is intentionally absent — hold-to-settlement is optimal (+15.5¢ vs +10.8¢ at PT=15%).
#   NO bands all reach 95¢+ within avg 2.5h; temperature cannot reverse once band is cleared.
# noaa_observed:yes=0.50, metar:yes=0.50 — observed temp exceeds strike; near-locked but reversible
# eia/eia_inventory=0.90 — WTI contracts volatile intraday; early exits were historically premature
#EXIT_SOURCE_PROFIT_TAKE={"noaa_observed:yes": 0.50, "noaa_observed": 0.75, "metar:yes": 0.50, "metar": 0.80, "nws_alert": 0.80, "eia": 0.90, "eia_inventory": 0.90, "noaa_day2:no": 0.07, "noaa_day2_early:no": 0.07, "noaa_day2:yes": 0.35, "noaa_day2_early:yes": 0.35, "noaa": 0.40, "noaa_day2": 0.20, "polymarket": 0.25, "obs_trajectory:yes": 0.30, "band_arb:yes": 0.15, "binance": 0.35, "coinbase": 0.35}

# Floor-price stop-loss suppression: if the current exit price (NO price for
# NO positions, YES bid for YES positions) is at or below this many cents,
# the stop-loss is suppressed entirely — the position is already at rock bottom
# with no further downside, and can only recover toward 100¢ at settlement.
# Stopping out here locks in the full loss with zero chance of recovery.
# Example: KXHIGHTATL-26APR19-T70 stopped at 0¢ for -$7.38; holding to
# settlement would have recovered the position if official high ≥ 70°F.
# Default: 2 (suppress when NO/YES exit price ≤ 2¢).
EXIT_STOP_LOSS_FLOOR_PRICE=2

# Source-specific stop-loss thresholds (JSON dict). Same key semantics as above.
# band_arb=0.95 — NO signals are near-certain; only cut if essentially worthless
# band_arb:yes=0.70 — wide SL gives spikes room to develop; backtest shows low SL rate (9%) with wide SL
#EXIT_SOURCE_STOP_LOSS={"noaa_observed:yes": 0.50, "metar:yes": 0.05, "nws_climo:yes": 0.05, "nws_alert:yes": 0.05, "noaa_observed": 0.70, "metar": 0.60, "noaa": 0.30, "owm": 0.50, "open_meteo": 0.50, "polymarket": 0.20, "manifold": 0.40, "metaculus": 0.50, "eia": 0.95, "eia_inventory": 0.95, "noaa_day2:yes": 0.45, "noaa_day2_early:yes": 0.45, "noaa_day2:no": 0.55, "noaa_day2_early:no": 0.55, "noaa_day2": 0.30, "hrrr": 0.40, "band_arb": 0.95, "band_arb:yes": 0.70, "binance": 0.25, "coinbase": 0.25}

# Source-specific trailing drawdown thresholds (JSON dict). Same key semantics.
# band_arb:yes is intentionally ABSENT — backtest shows trailing stop destroys value (+0.3¢ to -1.4¢
#   trailing vs +8.5¢ fixed PT). YES positions spike sharply and hold; trailing cuts winners short.
#EXIT_SOURCE_TRAILING_DRAWDOWN={"noaa_day2": 0.00, "noaa_day2_early": 0.05, "noaa_day2:yes": 0.12, "noaa_day2_early:yes": 0.12, "noaa_day2:no": 0.10, "noaa_day2_early:no": 0.10, "noaa:no": 0.08, "owm:no": 0.08, "open_meteo:no": 0.08, "noaa_observed:no": 0.30, "hrrr:no": 0.08, "noaa": 0.00, "noaa_observed": 0.15, "polymarket": 0.00, "binance": 0.20, "coinbase": 0.20}

# Minimum resolved trades per source before auto-calibration replaces the
# static KELLY_DEFAULT_P. Below this the static prior is used unchanged.
# Default: 20 (enough for a meaningful win-rate estimate).
KELLY_CALIBRATION_MIN_SAMPLES=20

# Minutes before the same ticker can be traded again (prevents re-buying the
# same market every cycle). Default: 240 (4 hours). Set to 0 to disable.
TRADE_TICKER_COOLDOWN_MINUTES=240

# Add-on (position averaging) controls.
# When an open position already exists on the exact same ticker+side, the bot
# may add more contracts if the signal remains strong. Kelly handles price
# conditioning automatically — if the market moved against us, cost rises and
# Kelly recommends fewer (or zero) new contracts.
#
# Minimum minutes between consecutive add-ons on the same ticker. Prevents
# the bot from adding one trade per poll cycle while the signal holds.
# Default: 60. Set to 0 to disable the time gate.
ADDON_MIN_GAP_MINUTES=60
#
# Maximum total open contracts per ticker+side across the original entry and
# all add-ons combined. Limits total dollar exposure per market.
# Default: 20 contracts (≈$10 at 50¢ cost). Set to 0 to disable.
ADDON_MAX_TOTAL_CONTRACTS=20

# -----------------------------------------------------------------------------
# Band-Arb NO Signal (temperature passed through band)
# -----------------------------------------------------------------------------

# NO ask price entry window. Bands with NO_ask > MAX have too little remaining
# gain to be worth entering (e.g. NO_ask=95¢ → max possible gain = 5¢).
# Backtest: ≤85¢ filter raises avg P&L from +10.8¢ to +21¢ per trade with PT=15%.
# Bands ≥81¢ have only 5% gain headroom; they converge in ~1.6h anyway.
# Default: 85¢ (was 99¢)
BAND_ARB_MAX_NO_ASK=95
# Min NO ask — skip if market already fully repriced (almost no edge left) OR if
# the market is pricing NO too cheaply (strongly disagrees with our observation,
# likely a stale/wrong METAR reading). Backtesting: all 1-20c NO trades lost.
# Default: 20¢
BAND_ARB_MIN_NO_ASK=20
# HRRR contradiction veto: if HRRR forecast for today's high is more than this
# many °F below the METAR observed max AND HRRR is also below the band ceiling
# (HRRR agrees with YES winning), block the NO signal. Catches stale METAR carry
# at midnight when the previous day's peak lingers while HRRR correctly predicts
# a cold day. Set to 0 to disable. Default: 8.0°F
BAND_ARB_HRRR_CONTRADICT_F=8.0
# NWS rounding buffer for KXLOWT band_arb — always applied.  0.5°F ensures
# METAR is clearly below the floor so NWS integer rounding can't put the
# official low back in-band (same logic as the +0.5 buffer for HIGH markets).
BAND_ARB_LOW_BUFFER_F=0.5
# Extra buffer applied when noaa_observed has no data yet (midnight→~1 AM gap,
# or api.weather.gov data outage).  Without NOAA to confirm, the effective
# floor becomes band_floor - (BUFFER_F + NOAA_ABSENT_BUFFER_F) = floor - 2.5°F,
# guarding against QC-rejected METAR anomalies before NOAA comes online.
BAND_ARB_LOW_NOAA_ABSENT_BUFFER_F=2.0
# NOAA contradiction guard (always active when noaa_observed is fresh):
# If noaa_observed shows the running overnight min ≥ band_floor - 0.5°F, the
# NWS-rounded official low would still be ≥ the floor (YES territory), so the
# NO signal is blocked regardless of what METAR shows.  The staleness filter in
# main.py ensures only today's noaa_observed values are used for this check.

# -----------------------------------------------------------------------------
# Band-Arb YES Signal
# -----------------------------------------------------------------------------

# Enable YES trades on KXHIGH "between" bands where the temperature is inside
# the band (as opposed to NO trades where the temperature has passed through).
# Default: true
BAND_ARB_YES_ENABLED=true

# Pre-lock tier: only fire within this many hours of market close.
# Prevents entering YES too early when temperature is still rising and could
# exit the band. At 4:30 PM local the "locked" tier takes over regardless.
# Default: 6.0 hours
BAND_ARB_YES_MAX_HOURS_PRELOCK=6.0

# YES ask price window. Outside this window there is no edge.
# MIN: Backtest shows ≥50¢ entry = 77% YES rate and +9.4¢/trade avg vs +2.7¢ overall.
#   Sub-50¢ entries are marginally positive at best; the 20-35¢ bucket is net negative.
# MAX: market strongly disagrees with YES signal. Default: 85¢
BAND_ARB_YES_MIN_YES_ASK=50
BAND_ARB_YES_MAX_YES_ASK=85

# Comma-separated city suffixes to skip for YES signals.
# AUS is the only city with net negative P&L in the backtest (-0.3¢/trade).
BAND_ARB_YES_BLACKLIST_CITIES=aus

# Buffer (°F) from each band edge before firing. Guards against NWS rounding
# placing the official reading outside the band. Default: 1.0°F
BAND_ARB_YES_BUFFER_F=1.0

# Maximum METAR vs NOAA divergence for YES signals. NOAA corroboration is
# REQUIRED for YES (no market-price fallback) to prevent Minneapolis-style
# METAR misreadings from firing YES trades. Default: 3.0°F
BAND_ARB_YES_MAX_DIVERGENCE_F=3.0

# Local hour and minute at which the daily high is considered "locked" inside
# the band (4:30 PM local — matches NOAA_OBS_PEAK_PAST_LOCAL_HOUR/MINUTE).
# After this time, the locked tier fires with LOCKED_OBS sizing.
BAND_ARB_YES_LOCK_LOCAL_HOUR=16
BAND_ARB_YES_LOCK_LOCAL_MINUTE=30

# p_win estimates for each YES tier.
# BASE_P: pre-lock baseline (clearance_factor + time_factor dynamically added).
#   Range: 0.62 (marginal, 6h out, near boundary) → ~0.92 (well-centered, at close)
# LOCKED_P: post-4:30 PM flat estimate — mirrors band_arb NO confidence.
BAND_ARB_YES_BASE_P=0.62
BAND_ARB_YES_LOCKED_P=0.88

# -----------------------------------------------------------------------------
# Forecast-driven NO signals (forecast_no strategy)
# -----------------------------------------------------------------------------

# Enable/disable forecast_no signals. Default: true
FORECAST_NO_ENABLED=true

# Minimum forecast-to-strike edge (°F) for a source's value to count.
# With NOAA day-1 MAE ~3-4°F, 5°F gives P(correct direction) > 85%.
FORECAST_NO_MIN_EDGE_F=5.0

# Number of independent forecast sources required. Default: 2
# (hrrr, nws_hourly, open_meteo, noaa all count as 1 each)
FORECAST_NO_MIN_SOURCES=2

# Minimum NO ask — skip near-certain-YES markets. 15¢ → max 85¢ YES bid.
# Buys at 1-2¢ NO have essentially no information edge and large loss exposure.
FORECAST_NO_MIN_ASK=15

# Maximum NO ask — don't chase already-priced markets. 70¢ cap.
# Backtest: NO-settling bands open ~55-65¢; 70¢ cap keeps meaningful upside.
FORECAST_NO_MAX_ASK=70

# Cities to skip for forecast_no (low historical hit rate). Default: aus
FORECAST_NO_BLACKLIST_CITIES=aus

# Local hour (city-local) at/after which the overnight low window is considered
# closed for LOW market veto checks. noaa_observed only queries midnight→5AM
# for temp_low_* to avoid afternoon highs, so by 6AM that reading is final.
# After this hour, if observed_min > strike for a LOW "over" market, YES is
# confirmed and the forecast_no signal is blocked. Default: 6
FORECAST_NO_OVERNIGHT_LOCK_HOUR=6

# Require at least one near-term model (hrrr or nws_hourly) in qualifying sources.
# Day-ahead global models (open_meteo, noaa) have 4-5°F MAE vs 2-3°F for HRRR/NWS.
# Without near-term corroboration the signal confidence is insufficient. Default: true
FORECAST_NO_REQUIRE_NEAR_TERM=false

# For LOW "under" markets (NO wins if overnight low stays above strike), block
# entries at or after this local hour. Overnight cooling begins ~15:00 and model
# accuracy for minimum temperatures drops sharply. Default: 15 (3 PM local)
FORECAST_NO_LOW_UNDER_MAX_HOUR=15

# Midnight METAR gap veto: block LOW "under" forecast_no signals during the
# overnight window (local hour < FORECAST_NO_OVERNIGHT_LOCK_HOUR=6) when no
# METAR observation exists yet.  The running minimum resets at midnight leaving
# ~15 minutes where the proximity veto cannot fire.  Set to false to disable.
FORECAST_NO_LOW_UNDER_REQUIRE_METAR=true

# HRRR dissent veto: block forecast_no if HRRR forecasts the daily high/low on
# the WRONG side of the strike (HRRR predicts YES while we'd be betting NO).
# HRRR is the most accurate short-range terrain-aware model; its dissent signals
# local dynamics (e.g. Rocky Mountain front-range cooling) that global models miss.
FORECAST_NO_HRRR_VETO=true

# Observed-minimum proximity margin for LOW-temperature forecast_no signals (°F).
# Block the NO trade if the running observed minimum (metar/noaa_observed) is within
# this distance of the strike — further overnight cooling would trigger YES.
# Default 2.0°F; set to 0 to disable.
FORECAST_NO_LOW_OBS_MARGIN_F=2.0

# Late-day HIGH-market METAR gap veto.  After FORECAST_NO_HIGH_LATE_HOUR (local),
# block if the METAR running max is more than FORECAST_NO_HIGH_LATE_MARGIN_F below
# the strike.  Temperature has peaked; it won't bridge the gap in the afternoon.
# Default: 15 (3 PM local), 2.0°F.  Set LATE_HOUR=24 to disable.
FORECAST_NO_HIGH_LATE_HOUR=15
FORECAST_NO_HIGH_LATE_MARGIN_F=2.0

# Pre-dawn proximity veto for LOW "over" (T-type) markets (YES = low > strike).
# Blocks forecast_no NO signals when the running observed minimum is still well above
# the strike — meaning the required temperature drop before dawn is implausible.
#
# The required margin scales with hours remaining until dawn (lock hour), so the veto
# is lenient at midnight and tightens as dawn approaches:
#
#   required_margin = MARGIN_F + MARGIN_PER_HOUR × (lock_hour − local_hour − 1)
#
# Example with defaults (base=2.0, per_hour=0.75, lock=6):
#   midnight (hour 0) → 2.0 + 0.75×5 = 5.75°F required gap above strike to veto
#   3 AM              → 2.0 + 0.75×2 = 3.50°F
#   5 AM              → 2.0 + 0.75×0 = 2.00°F  (nearly dawn — tightest)
#
# Set OBS_MIN_HOUR=3 to restore the old fixed-margin behaviour (no midnight coverage).
FORECAST_NO_LOW_OVER_OBS_MIN_HOUR=0
FORECAST_NO_LOW_OVER_OBS_MARGIN_F=2.0
FORECAST_NO_LOW_OVER_OBS_MARGIN_PER_HOUR=1.0

# Terrain-city HRRR minimum-edge gate.
# For cities in FORECAST_NO_HRRR_TERRAIN_CITIES, HRRR must be present with
# edge >= this value (°F) before the forecast_no signal can fire.  Default 2.0°F.
FORECAST_NO_HRRR_TERRAIN_MIN_EDGE_F=2.0

# Comma-separated city codes (temp_high_*/temp_low_* metric suffixes) where the
# terrain-city HRRR gate applies.  Default: Denver only.  Add "phx,las" etc. as needed.
FORECAST_NO_HRRR_TERRAIN_CITIES=den

# Global model-spread gate threshold (°F).  If HRRR disagrees with NWS-hourly or
# OpenMeteo by more than this value AND HRRR edge < TERRAIN_MIN_EDGE_F, block the
# trade for any city.  Default 4.0°F.
FORECAST_NO_HRRR_SPREAD_F=4.0

# Maximum allowed spread (°F) between highest and lowest weather-model forecast
# before the signal is blocked.  Applies to all market directions including band
# markets.  Backtests show 0% win rate when model spread exceeds 5°F.  Set to 0
# to disable.  Default 5.0°F.
FORECAST_NO_MODEL_SPREAD_F=5.0

# -----------------------------------------------------------------------------
# Circuit Breaker
# -----------------------------------------------------------------------------

# Pause trading after this many consecutive losses. Default: 3
CIRCUIT_BREAKER_CONSECUTIVE_LOSSES=3

# Hours to pause after the circuit breaker trips. Default: 12.0
# 12 hours lets the bot resume for the next day's late-morning signals
# while still cooling off after a bad streak. The old 24h pause blocked
# an entire trading day when weather/BTC ran into a losing streak.
CIRCUIT_BREAKER_PAUSE_HOURS=12.0

# Maximum number of simultaneously open positions. Default: 5
CIRCUIT_BREAKER_MAX_OPEN=5

# -----------------------------------------------------------------------------
# Signal Quality Filters (numeric / NOAA weather)
# -----------------------------------------------------------------------------

# Minimum temperature forecast edge (°F) for raw NWS forecast signals.
# NWS day-1 MAE ≈ 3–4°F; a 7°F edge (≈ 2σ) is the minimum worth trading.
# Only applies to source="noaa" or "owm". Default: 7.0. Set to 0 to disable.
TEMP_FORECAST_MIN_EDGE=7.0

# Minimum edge (°F) for day-2+ NWS extended forecasts (source="noaa_day2" etc.).
# Day-2 MAE ≈ 5–6°F vs 3–4°F for day-1; same 7°F edge = only ~1.1σ vs ~1.6σ for day-1.
# Default: 9.0 (restores ~1.5σ entry quality, comparable to day-1 at 7°F).
# Set to 0 to apply TEMP_FORECAST_MIN_EDGE to all forecast sources uniformly.
TEMP_DAY2_MIN_EDGE=9.0

# Minimum edge (°F) for station-observed temperature signals.
# Raised from 2.0 to 5.0: Kalshi settles against a specific major-airport
# ASOS station; the bot queries the nearest NWS station, which can differ
# by 1–3°F. A 5°F buffer prevents station-mismatch losses on near-threshold
# markets. Default: 5.0. Set to 0 to disable.
TEMP_OBSERVED_MIN_EDGE=5.0

# Hours before market close within which noaa_observed NO signals are allowed.
# If the observed max is still below the strike with >N hours remaining, the
# temperature may still rise and the NO signal is too uncertain to trade.
# YES signals (observed max already above strike) are always surfaced.
# Default: 4.0. Set to 0 to disable.
TEMP_OBSERVED_MAX_HOURS=4.0

# Maximum spread (°F) between the NWS daily forecast and the HRRR hourly high
# before forecast-based signals (noaa/owm) are suppressed. A large spread
# means the atmosphere is convectively uncertain and the forecast is unreliable.
# noaa_observed and nws_alert are always exempt. Default: 5.0.
HRRR_MAX_SPREAD_F=5.0

# 1-sigma uncertainty (°F) used when converting noaa_observed edge to P(YES).
# The old hardcoded 0.5°F produced p≈1.0 even at 2°F above the strike.
# 2.0°F reflects the real station-mismatch uncertainty (Kalshi uses a
# different ASOS station than the NWS obs station the bot queries).
# At 5°F edge this yields p≈0.994 (tight but not numerically 1.0).
NOAA_OBSERVED_SIGMA=2.0

# Open-Meteo ensemble weather forecast (free, no API key required).
# OPEN_METEO_MODEL: ensemble model name. gfs_seamless = 31 members.
#   Other options: ecmwf_ifs_ensemble (51 members), icon_seamless.
OPEN_METEO_MODEL=gfs_seamless
# Ensemble std dev below which the signal is promoted to "open_meteo_tight"
# (treated like noaa_observed: lower edge threshold, no HRRR gate). Default: 2.0°F.
OPEN_METEO_MIN_SPREAD_F=2.0
# Ensemble std dev above which the signal is suppressed entirely (too uncertain).
# Default: 6.0°F. Set to 0 to disable.
OPEN_METEO_MAX_SPREAD_F=6.0

# Equity index prices (S&P 500, Nasdaq) via Yahoo Finance — no API key needed.
# Set to false to skip pre/post-market prices and use only regular-session data.
EQUITY_INDEX_PREMARKET=true

# Minimum temperature forecast edge (°F) before TRADING a weather market.
# NWS day-1 forecasts have MAE ≈ 3–4°F; smaller edges are within noise.
# Only applies to "temp_high" metrics. Default: 4.0. Set to 0 to disable.
NUMERIC_MIN_TEMP_EDGE=4.0

# Minimum disagreement between data-implied P(YES) and market-implied P(YES).
# Prevents trading when the market has already priced in the signal.
# Default: 0.20 (20 percentage points). Set to 0 to disable.
NUMERIC_MIN_DISAGREEMENT=0.20

# NWS day-1 temperature forecast uncertainty (1-sigma, °F).
# Used to convert forecast edge into an implied probability. Default: 4.0
TEMP_FORECAST_SIGMA=4.0

# Minimum numeric edge before any opportunity surfaces (all metrics).
# Default: 0 (disabled). Use metric-specific filters above for temperature.
NUMERIC_MIN_EDGE=0

# P(win) prior for trades backed by observed station data (source=noaa_observed).
# Observed temps are near-certain outcomes, warranting a higher p than forecasts.
# Overrides KELLY_DEFAULT_P / KELLY_METRIC_PRIORS for observed-source trades.
# Default: 0.80
NOAA_OBSERVED_P=0.80

# Tight stop-loss for YES trades on KXLOWT (daily-low) markets from observed
# sources (noaa_observed, metar).  Unlike KXHIGHT, the morning running-minimum
# above the strike is not a locked outcome — a cold front can push the daily low
# well below strike later in the day.  Default: 0.20 (20% of cost). Set to 0
# to disable and fall back to EXIT_SOURCE_STOP_LOSS["noaa_observed:yes"].
KXLOWT_OBS_YES_STOP_LOSS=0.20

# Gate: suppress noaa_observed / metar YES signals on KXLOWT daily-low markets
# when any forecast model (noaa, hrrr, nws_hourly, open_meteo) predicts the
# daily low within LOWT_FORECAST_GATE_BUFFER_F degrees of (or below) the strike.
# Prevents observed morning running-minimum YES entries that contradict forecasts.
# Default: true. Set to false to disable (not recommended for Chicago in April).
NUMERIC_LOWT_FORECAST_GATE=true
# Buffer added to strike for the gate check (°F). Accounts for NWS day-1 MAE
# ≈ 3–4°F: a forecast of 54°F vs 53°F strike is dangerously close. Default: 3.0.
LOWT_FORECAST_GATE_BUFFER_F=3.0

# Hours before market close at which forecast-only weather trades are blocked.
# Late in the day, NWS forecasts are stale; actual temps are nearly determined.
# Observed-data trades (noaa_observed) are always exempt from this cutoff.
# Set to 0 to disable. Default: 6.0
SAME_DAY_CUTOFF_HOURS=6.0

# Maximum cost (cents) to enter a numeric position (contrarian filter).
# YES trade: blocked if yes_ask > this. NO trade: blocked if 100-yes_bid > this.
# Prevents buying into a market that has already priced in the data signal.
# Set to 0 to disable. Default: 40
CONTRARIAN_MAX_ENTRY_CENTS=40

# Minimum market price (cents) on our side before entering a trade.
# Mirror of CONTRARIAN_MAX_ENTRY_CENTS. When the market prices our side
# below this floor, the collective orderbook is near-certain we are wrong —
# usually caused by a data-source station mismatch (e.g. NOAA observed max
# from the wrong NWS station shows 68°F while Kalshi's official resolution
# station is at 60°F, so the market sits at 1¢ YES while our model says p=1.0).
# YES trade: blocked if yes_ask < this. NO trade: blocked if 100-yes_bid < this.
# Set to 0 to disable. Default: 3
MARKET_MIN_PRICE_CENTS=3

# -----------------------------------------------------------------------------
# Signal Quality Filters (scheduled data releases)
# -----------------------------------------------------------------------------

# Maximum minutes after a BLS/FRED/EIA scheduled release during which numeric
# opportunities are allowed to trigger trades. Outside this window the data is
# already priced in. Set to 0 to disable the gate. Default: 30
RELEASE_WINDOW_MINUTES=30

# Number of EDGAR 8-K filings to fetch per cycle. Default: 40. Raise to 100+
# to capture more company-event filings (SEC rate-limits, so don't go above 200).
EDGAR_FETCH_COUNT=100

# Box office weekend chart (The Numbers, no API key required).
# Minimum Jaccard title-similarity [0–1] to match a movie to a Kalshi market.
BOX_OFFICE_MIN_MATCH=0.40
# Minimum gap ($M) between estimated gross and Kalshi strike before surfacing a trade.
# $10M ≈ 1 studio-estimate standard deviation for major releases.
BOX_OFFICE_MIN_EDGE_M=10.0
# Drop box office data older than this many days (prevents stale actuals after settlement).
BOX_OFFICE_MAX_STALE_DAYS=4

# Maximum age (calendar days) of EIA data before it is considered stale.
# EIA daily spot prices are published with a 1-business-day lag; over a
# weekend the lag grows to 3 days. Stale data is dropped before matching.
# Default: 1 (allow yesterday's data; block data older than 1 day).
# Set to 7 to effectively disable.
EIA_MAX_STALE_DAYS=1

# EIA open data API key (free at https://www.eia.gov/opendata/).
# Required for WTI crude oil and Henry Hub natural gas numeric matching.
# Leave blank to disable EIA data fetch.
EIA_API_KEY=

# WTI front-month futures price from Yahoo Finance (CL=F) — no API key required.
# Provides real-time CME NYMEX price (1–3 min delay) for KXWTI markets, replacing
# the 1-day-lagged EIA spot as the primary WTI signal source.
WTI_FUTURES_ENABLED=true

# -----------------------------------------------------------------------------
# Signal Quality Filters (crypto)
# -----------------------------------------------------------------------------

# Hours before market close within which daily-close crypto trades are allowed.
# Applies to KXBTCD, KXDOGE, KXADA, KXAVAX, KXLINK (non-15M daily markets).
# Binance spot price diverges from the settlement price when hours remain.
# 15-minute markets (KXBTC15M, KXDOGE15M, etc.) are always exempt.
# Set to 0 to disable. Default: 2.0
CRYPTO_DAILY_CLOSE_HOURS=2.0

# -----------------------------------------------------------------------------
# Signal Quality Filters (forex / ECB)
# -----------------------------------------------------------------------------

# Maximum age (calendar days) of ECB/Frankfurter data before it is considered
# stale. ECB reference rates publish once per day at ~16:00 CET (~10:00 AM ET).
# Before that publication the only available rate is yesterday's, which is
# already fully priced into the market and provides no directional signal.
# Default: 0 (same-day data only). Set to 7 to disable.
FOREX_MAX_STALE_DAYS=0

# GDPNow staleness gate — drop Atlanta Fed GDPNow (FRED GDPNOW series) if the
# series date is older than N calendar days.  GDPNow updates ~2-3x per week
# during the quarter; 5 days covers weekends and minor gaps while blocking the
# inter-quarter stale period (after BEA advance estimate, before new quarter starts).
# Set to 30 to disable and always use the most recent available estimate.
GDPNOW_MAX_STALE_DAYS=5

# Hours before market close within which KXEURUSD and KXUSDJPY trades are
# allowed. The ECB fixing and Kalshi resolution both land at ~10 AM ET; the
# rate is not predictive of the fixing until it IS the fixing.
# Set to 0 to disable. Default: 1.0
FOREX_CLOSE_HOURS=1.0

# -----------------------------------------------------------------------------
# External Forecast Matching (Polymarket / PredictIt / Metaculus / Manifold)
# -----------------------------------------------------------------------------

# Polymarket — real-money, global. Strongest signal tier.
POLY_MIN_DIVERGENCE=0.20      # min |poly_p - kalshi_p| to surface. Default: 0.20
POLY_MIN_LIQUIDITY=5000       # min USD liquidity. Default: 5000
POLY_MIN_MATCH_SCORE=0.20     # min Jaccard keyword similarity. Default: 0.20

# PredictIt — real-money, US-regulated, specialises in political markets.
PDIT_MIN_DIVERGENCE=0.15      # lower threshold: political prices well-calibrated
PDIT_MIN_VOLUME=500           # min today's USD volume (stale market filter)
PDIT_MIN_MATCH_SCORE=0.20

# Metaculus — reputation-tracked crowd forecasting, well-calibrated.
META_MIN_DIVERGENCE=0.20
META_MIN_FORECASTERS=20       # min forecasters (quality filter)
META_MIN_MATCH_SCORE=0.20

# Manifold — play-money (mana). Noisier; higher divergence threshold required.
MANI_MIN_DIVERGENCE=0.25
MANI_MIN_LIQUIDITY=3000       # min mana liquidity
MANI_MIN_MATCH_SCORE=0.35
MANI_MAX_PROB=0.95            # reject frozen/resolved markets (p>0.95 or p<0.05)

# Manifold consensus gates — prevent acting on Manifold-only divergences.
# Block Manifold-only signals above this divergence unless another real-money
# platform independently agrees. Default: 0.50
MANI_MAX_SOLO_DIVERGENCE=0.50
# Hard cap: block all Manifold signals above this regardless of consensus.
# Default: 0.40
MANI_HARD_CAP_DIVERGENCE=0.40

# -----------------------------------------------------------------------------
# Training Data
# -----------------------------------------------------------------------------

# Maximum hours before resolution an article must be published to qualify as
# training data. Articles published >7 days before resolution rarely have
# predictive signal (the outcome-determining event hasn't happened yet).
# Default: 168 (7 days). Set to 0 to disable.
MAX_HOURS_BEFORE=168

# Path to the fine-tuned DistilBERT classifier for text opportunity direction.
# Default: models/kalshi_classifier/ (relative to project root)
# CLASSIFIER_MODEL_PATH=models/kalshi_classifier

# Minimum |p_yes - 0.5| required to act on a classifier signal for text trades.
# 0.20 means only trade when model is ≥70% or ≤30% confident. Default: 0.20
TEXT_MIN_CONFIDENCE=0.20

# -----------------------------------------------------------------------------
# Dry-Run Ledger
# -----------------------------------------------------------------------------

# Starting capital for the dry-run P&L simulation (dollars). Default: 100
DRY_RUN_STARTING_CAPITAL=100

# Path to the dry-run overview file. Default: dry_run_overview.txt in project root
# DRY_RUN_OVERVIEW_PATH=/custom/path/dry_run_overview.txt

# -----------------------------------------------------------------------------
# Structured Government Event Sources
# -----------------------------------------------------------------------------

# congress.gov API key (free at https://api.congress.gov/sign-up/).
# Required for congressional vote matching.  Leave blank to disable.
CONGRESS_API_KEY=

# Minimum title-overlap score [0–1] to match a vote to a Kalshi market.
# Default: 0.25  (at least 25% of the shorter title's content words must overlap)
CONGRESS_MATCH_THRESHOLD=0.25

# How often to poll the congress.gov vote list (seconds). Default: 300
# Detail records are only fetched for votes not yet seen, so actual API usage
# is much lower than one call per interval.
CONGRESS_POLL_INTERVAL=300

# Minimum title-overlap score for White House EO → Kalshi market matching.
# Default: 0.25
WH_MATCH_THRESHOLD=0.25
